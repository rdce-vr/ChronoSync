# GEMINI_API_KEY: Required if using Gemini AI features.
# Generate one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The external URL where this app is hosted.
# Used for self-referential links and API endpoints.
# Example: http://localhost:7332 or https://chronos.example.com
APP_URL="http://localhost:7332"

# PORT: The port the web server listens on inside the container.
PORT=7332
